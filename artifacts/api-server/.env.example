# ============================================================
# CreatorOS AI — API Server Environment Variables
# Copy to .env for local development. NEVER commit .env.
# ============================================================

# ── Server ────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development
LOG_LEVEL=debug

# ── Database (auto-set by Replit; set manually for Vercel) ───
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── AI Providers ─────────────────────────────────────────────
# Groq — https://console.groq.com
GROQ_API_KEY=gsk_...

# Hugging Face — https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hf_...

# ── Payments ─────────────────────────────────────────────────
# Paystack — https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY=sk_live_...
PAYSTACK_PUBLIC_KEY=pk_live_...

# ── Supabase (server-side admin) ──────────────────────────────
# From: Supabase Project → Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Deployment ────────────────────────────────────────────────
# Production frontend URL — used for CORS and Paystack callback redirects
FRONTEND_URL=https://your-app.vercel.app
