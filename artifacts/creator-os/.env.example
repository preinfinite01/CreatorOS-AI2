# ============================================================
# CreatorOS AI — Frontend Environment Variables
# VITE_ prefix required — these are bundled into the client build.
# NEVER put secrets here — they are visible to all users.
# ============================================================

# ── Supabase (public keys — safe to expose) ───────────────────
# From: Supabase Project → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ── Paystack (public key — safe to expose) ────────────────────
VITE_PAYSTACK_PUBLIC_KEY=pk_live_...

# ── API Backend URL (your Render backend) ─────────────────────
# Replace with your actual Render backend URL
# Example: https://creatoros-api.onrender.com
VITE_API_URL=https://your-backend-url.onrender.com
